# Multi-trader format (v3) — Name:portfolioId[:type], comma-separated
# type = "cfd" (default) or "futures"
# The portfolioId is the number at the end of the my-portfolio URL on Bitget
TRADERS=DKTrading:1443199880395776000,Futures:1427930164156649472:futures

# Cookie from Bitget (paste via dashboard, or set here as fallback on redeploy)
BITGET_COOKIE=

# Poll interval in seconds (default 120)
POLL_INTERVAL_SEC=120

# Legacy single-trader vars (ignored when TRADERS is set)
# PORTFOLIO_ID=1443199880395776000
# TRADER_NAME=DKTrading
